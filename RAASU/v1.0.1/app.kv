BoxLayout:
    orientation: "vertical"
    padding: 10
    spacing: 8


    BoxLayout:
        size_hint_y: None
        height: "55dp"

        canvas.before:
            Color:
                rgba: 0.0,0.1,0.4,1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Ra'asu Ventures"
            color: 1,1,1,1
            bold: True
            font_size: 20

        Label:
            id: datetime_label
            text: ""
            color: 1,1,1,1
            halign: "right"


    BoxLayout:
        size_hint_y: None
        height: "45dp"
        spacing: 10


        Label:
            text: "Fruit Mixed Salad"
            font_size: 18
            size_hint_x: .35


        Label:
            text: "₦1,500"
            font_size: 18
            size_hint_x: .15


        TextInput:
            id: qty
            hint_text: "QTY"
            multiline: False
            input_filter: "int"
            size_hint_x: .1


        TextInput:
            id: customer
            hint_text: "Customer (optional)"
            multiline: False
            size_hint_x: .25


        Button:
            text: "PRINT"
            size_hint_x: .15
            on_press: app.confirm_print()


    Label:
        id: status
        text: ""
        color: 1,0,0,1
        size_hint_y: None
        height: "25dp"


    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 6

        Label:
            text: "TODAY SALES SUMMARY"
            bold: True

        Label:
            id: total_items
            text: "Total Items Sold: 0"

        Label:
            id: total_revenue
            text: "Total Revenue: ₦0"